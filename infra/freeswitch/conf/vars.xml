<include>
  <!-- Talkie FreeSWITCH Configuration -->
  <X-PRE-PROCESS cmd="set" data="default_password=ClueCon"/>
  <X-PRE-PROCESS cmd="set" data="domain=talkie.local"/>
  <X-PRE-PROCESS cmd="set" data="domain_name=$${domain}"/>
  <X-PRE-PROCESS cmd="set" data="hold_music=silence"/>
  <X-PRE-PROCESS cmd="set" data="use_profile=external"/>
  <X-PRE-PROCESS cmd="set" data="default_areacode=918"/>
  <X-PRE-PROCESS cmd="set" data="default_country=US"/>

  <!-- ESL -->
  <X-PRE-PROCESS cmd="set" data="event_socket_password=ClueCon"/>

  <!-- External IP (set to your public IP in production) -->
  <X-PRE-PROCESS cmd="stun-set" data="external_rtp_ip=stun:stun.l.google.com:19302"/>
  <X-PRE-PROCESS cmd="stun-set" data="external_sip_ip=stun:stun.l.google.com:19302"/>

  <!-- Codec preferences -->
  <X-PRE-PROCESS cmd="set" data="global_codec_prefs=PCMU,PCMA,OPUS,G722"/>
  <X-PRE-PROCESS cmd="set" data="outbound_codec_prefs=PCMU,PCMA,OPUS,G722"/>

  <!-- Talkie API server for webhooks -->
  <X-PRE-PROCESS cmd="set" data="talkie_api_url=http://api:3000"/>
</include>
