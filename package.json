    "uuid": "^11.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "dotenv": "^16.4.0",
    "zod": "^3.24.0",
    "modesl": "^1.2.0",
    "fastify-plugin": "^5.0.0",
    "nanoid": "^5.0.0",
    "ws": "^8.18.0"
